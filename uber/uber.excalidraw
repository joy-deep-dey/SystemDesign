    {
      "id": "RktddXZkcikKai4winL3_",
      "type": "text",
      "x": 468,
      "y": -4073.999755859375,
      "width": 200.742786377709,
      "height": 711.588235294118,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3F",
