      "seed": 125222347,
      "version": 692,
      "versionNonce": 520627056,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1780562627734,
      "link": null,
      "locked": false,
      "text": "FR:\n- Book tickets\n- View event details\n- Search for events\n\nNFR:\n- consistency >> availability\n(no double booking)\n    - consistency in booking\n    - availability for search\n- read >> write\n\nCore Entities:\n- Events\n- Venue\n- Performer\n- Ticket\n\nAPI:\nGet /event/:eventId ->\nEvent, Venue, ticket,\nperformer\n\nGet\n/search?term={term}&locat\nion={loc}\n\nPOST /booking/reserve\nbody: {\n    userID,\n    ticketId\n    }\n\nPost /booking/confirm\nbody{\n    bookingId,\n    paymentDertails(stripe)\n    }",
      "fontSize": 14.980804953560371,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "FR:\n- Book tickets\n- View event details\n- Search for events\n\nNFR:\n- consistency >> availability (no double booking)\n    - consistency in booking\n    - availability for search\n- read >> write\n\nCore Entities:\n- Events\n- Venue\n- Performer\n- Ticket\n\nAPI:\nGet /event/:eventId -> Event, Venue, ticket, performer\n\nGet /search?term={term}&location={loc}\n\nPOST /booking/reserve\nbody: {\n    userID,\n    ticketId\n    }\n\nPost /booking/confirm\nbody{\n    bookingId,\n    paymentDertails(stripe)\n    }",
      "autoResize": false,
      "lineHeight": 1.25
    },
