    {
      "id": "wCUnOBoA5ULeDcjiLRmRG",
      "type": "text",
      "x": 213,
      "y": 151,
      "width": 251,
      "height": 520,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b48",
      "roundness": null,
      "seed": 837301616,
      "version": 663,
      "versionNonce": 284566416,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780565035574,
      "link": null,
      "locked": false,
      "text": "ApI:\nPOST /ride/fare-est -> Ride\n(partialData)\n{\n    source,\n    dest\n}\nPATCH /ride/request -> 200\n{\n    rideId\n}\nPOST /loc /update\n{\n    lat,\n    long\n}\nPATCH ride/driver/accept\n{\n    rideId,\n    true,false\n}\nPATCH ride/driver/update\n{\n    rideId,\n    status: picked, dropped\n}",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "ApI:\nPOST /ride/fare-est -> Ride (partialData)\n{\n    source,\n    dest\n}\nPATCH /ride/request -> 200\n{\n    rideId\n}\nPOST /loc /update\n{\n    lat,\n    long\n}\nPATCH ride/driver/accept\n{\n    rideId,\n    true,false\n}\nPATCH ride/driver/update\n{\n    rideId,\n    status: picked, dropped\n}",
      "autoResize": false,
      "lineHeight": 1.25
    },
