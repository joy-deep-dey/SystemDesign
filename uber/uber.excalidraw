    {
      "id": "q6Z3uCf_xkr88bRbFtXDr",
      "type": "text",
      "x": 213,
      "y": -236,
      "width": 253.97599999999994,
      "height": 420,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b45",
      "roundness": null,
      "seed": 253409168,
      "version": 700,
      "versionNonce": 1205136752,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780565033086,
      "link": null,
      "locked": false,
      "text": "FR:\n1. User can search rides\n2. User can book ride\n3. User can track ride loc\n\n4. Driver can accept/reject ride\n5. Navigate to user/dest\n\n6. Notifications for booking\nconfirmation, arrival etc.\n\nNFR:\n1. App should be highly available\n2. low latency for search and\nbooking\n3. near exact loc tracking\n4. consistent booking, 1 ride - 1\ndriver\n5. handle surges for peak hours\n\n",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "FR:\n1. User can search rides\n2. User can book ride\n3. User can track ride loc\n\n4. Driver can accept/reject ride\n5. Navigate to user/dest\n\n6. Notifications for booking confirmation, arrival etc.\n\nNFR:\n1. App should be highly available\n2. low latency for search and booking\n3. near exact loc tracking\n4. consistent booking, 1 ride - 1 driver\n5. handle surges for peak hours\n\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
